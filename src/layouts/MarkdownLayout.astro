---
// src/layouts/MarkdownLayout.astro
import Layout from './Layout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Footer from '../components/Footer.astro';
import RitualModal from '../components/RitualModal.astro';
import CyberMarquee from '../components/CyberMarquee.astro';

const { frontmatter, headings = [] } = Astro.props;
const title = frontmatter?.title || "赛博代码空间";
const description = frontmatter?.description || "赛博代码坟场中的一块数字遗迹";
const date = frontmatter?.date || "";
const tags = frontmatter?.tags || [];
const author = frontmatter?.author || "匿名黑客";

// 从标签列表中自动识别已知的项目状态，以供个性化状态主题色修饰
const knownStatuses = ['terminated', 'abandoned', 'deprecated', 'liquidated', 'delisted'];
const status = frontmatter?.status || tags.find(t => knownStatuses.includes(t.toLowerCase())) || "";
---

<Layout title={`${title} | 🪦 赛博代码坟场`} description={description}>
  <CyberMarquee frontmatter={frontmatter} />
  
  <div class="doc-container" data-status={status?.toLowerCase()}>
    <a href="/" class="back-btn">← [ESC] 返回坟场主页 // EXIT</a>
    
    <div class="layout-wrapper">
      <article class="article-card">
        <header class="article-header">
          <h1 class="article-title">{title}</h1>
          <div class="article-meta">
            {date && <div class="meta-item">⏱ 忌日 / 发布: <strong>{date}</strong></div>}
            {author && <div class="meta-item">✍ 守墓人: <strong>{author}</strong></div>}
          </div>
          {tags.length > 0 && (
            <div class="tag-list">
              {tags.map((tag) => (
                <span class="tag-item">#{tag}</span>
              ))}
            </div>
          )}
        </header>
        
        <div class="markdown-content">
          <slot />
        </div>
      </article>

      {headings && headings.length > 0 && (
        <aside class="sidebar-wrapper">
          <TableOfContents headings={headings} />
        </aside>
      )}
    </div>
  </div>

  <!-- 支持文章页面的赛博祭奠唤起 -->
  <RitualModal />
  
  <Footer />
</Layout>

<script>
  function initEscNavigation() {
    if ((window as any).__escNavigationHandler) {
      document.removeEventListener('keydown', (window as any).__escNavigationHandler);
    }

    const handleKeyDown = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        const modalOverlay = document.getElementById('ritualModalOverlay');
        const isModalActive = modalOverlay && modalOverlay.classList.contains('active');
        
        if (!isModalActive) {
          const backBtn = document.querySelector('.back-btn') as HTMLAnchorElement | null;
          if (backBtn) {
            backBtn.click();
          } else {
            window.location.href = '/';
          }
        }
      }
    };

    (window as any).__escNavigationHandler = handleKeyDown;
    document.addEventListener('keydown', handleKeyDown);
  }

  document.addEventListener('astro:page-load', initEscNavigation);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initEscNavigation();
  } else {
    document.addEventListener('DOMContentLoaded', initEscNavigation);
  }
</script>

<style is:global>
  /* 容器 */
  .doc-container {
    --page-accent: var(--color-secondary);
    --page-accent-h: var(--color-secondary-h);
    --page-accent-s: var(--color-secondary-s);
    --page-accent-l: var(--color-secondary-l);

    --page-primary: var(--color-primary);
    --page-primary-h: var(--color-primary-h);
    --page-primary-s: var(--color-primary-s);
    --page-primary-l: var(--color-primary-l);

    max-width: 880px;
    margin: 40px auto;
    padding: 0 24px;
    transition: max-width 0.3s ease;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 1024px) {
    .doc-container {
      max-width: 1200px;
    }
  }

  /* 针对 5 种项目状态进行个性化修饰色映射覆盖 */
  .doc-container[data-status="terminated"] {
    --page-accent: var(--color-status-terminated);
    --page-accent-h: var(--color-primary-h);
    --page-accent-s: var(--color-primary-s);
    --page-accent-l: var(--color-primary-l);

    --page-primary: var(--color-status-terminated);
    --page-primary-h: var(--color-primary-h);
    --page-primary-s: var(--color-primary-s);
    --page-primary-l: var(--color-primary-l);
  }
  .doc-container[data-status="abandoned"] {
    --page-accent: var(--color-status-abandoned);
    --page-accent-h: var(--color-accent-h);
    --page-accent-s: var(--color-accent-s);
    --page-accent-l: var(--color-accent-l);

    --page-primary: var(--color-status-abandoned);
    --page-primary-h: var(--color-accent-h);
    --page-primary-s: var(--color-accent-s);
    --page-primary-l: var(--color-accent-l);
  }
  .doc-container[data-status="deprecated"] {
    --page-accent: var(--color-status-deprecated);
    --page-accent-h: var(--color-secondary-h);
    --page-accent-s: var(--color-secondary-s);
    --page-accent-l: var(--color-secondary-l);

    --page-primary: var(--color-status-deprecated);
    --page-primary-h: var(--color-secondary-h);
    --page-primary-s: var(--color-secondary-s);
    --page-primary-l: var(--color-secondary-l);
  }
  .doc-container[data-status="liquidated"] {
    --page-accent: var(--color-status-liquidated);
    --page-accent-h: var(--color-warning-h);
    --page-accent-s: var(--color-warning-s);
    --page-accent-l: var(--color-warning-l);

    --page-primary: var(--color-status-liquidated);
    --page-primary-h: var(--color-warning-h);
    --page-primary-s: var(--color-warning-s);
    --page-primary-l: var(--color-warning-l);
  }
  .doc-container[data-status="delisted"] {
    --page-accent: var(--color-status-delisted);
    --page-accent-h: var(--color-decorative-h);
    --page-accent-s: var(--color-decorative-s);
    --page-accent-l: var(--color-decorative-l);

    --page-primary: var(--color-status-delisted);
    --page-primary-h: var(--color-decorative-h);
    --page-primary-s: var(--color-decorative-s);
    --page-primary-l: var(--color-decorative-l);
  }

  /* 响应式分栏布局 */
  .layout-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .layout-wrapper {
      grid-template-columns: 1fr 280px;
    }
  }

  .sidebar-wrapper {
    display: none;
  }

  @media (min-width: 1024px) {
    .sidebar-wrapper {
      display: block;
      position: sticky;
      top: 40px;
    }
  }

  /* 返回按钮 */
  .back-btn {
    display: inline-block;
    color: var(--page-accent);
    text-decoration: none;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.95rem;
    margin-bottom: 30px;
    border: 1px dashed hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.3);
    padding: 10px 20px;
    border-radius: 4px;
    background: hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.02);
    box-shadow: 0 0 10px hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.05);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .back-btn:hover {
    color: #000;
    background: var(--page-accent);
    border-color: var(--page-accent);
    box-shadow: 0 0 15px var(--page-accent);
    transform: translateX(-4px);
  }

  /* 主体卡片 */
  .article-card {
    background: color-mix(in srgb, var(--color-bg-base) 90%, transparent);
    border: 2px solid var(--color-border-subtle);
    border-radius: 8px;
    padding: 40px 30px;
    box-shadow: 
      0 10px 35px rgba(0, 0, 0, 0.7),
      inset 0 1px 1px rgba(255, 255, 255, 0.05);
    position: relative;
    overflow: hidden;
  }

  /* 发光边角装饰 */
  .article-card::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 25px 25px 0;
    border-color: transparent var(--page-primary) transparent transparent;
    filter: drop-shadow(0 0 3px var(--page-primary));
  }

  .article-header {
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: 30px;
    margin-bottom: 40px;
  }

  .article-title {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 900;
    color: var(--color-text-primary);
    text-shadow: 0 0 15px hsla(0, 0%, 100%, 0.15);
    margin-bottom: 15px;
    line-height: 1.3;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 20px;
  }

  .meta-item {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .meta-item strong {
    color: var(--color-text-primary);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-item {
    font-size: 0.75rem;
    color: var(--page-accent);
    background: hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.08);
    border: 1px solid hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.2);
    border-radius: 4px;
    padding: 3px 8px;
  }

  /* ================== Markdown 文章内部渲染样式 ================== */
  .markdown-content {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .markdown-content p {
    margin-bottom: 24px;
  }

  .markdown-content h2, 
  .markdown-content h3, 
  .markdown-content h4 {
    font-family: 'Orbitron', sans-serif;
    color: var(--color-text-primary);
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .markdown-content h2 {
    font-size: 1.6rem;
    border-bottom: 1px dashed var(--color-border-subtle);
    padding-bottom: 10px;
  }

  .markdown-content h3 {
    font-size: 1.25rem;
    color: var(--page-accent);
    text-shadow: 0 0 8px hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.25);
  }

  .markdown-content a {
    color: var(--page-accent);
    text-decoration: none;
    border-bottom: 1px dotted var(--page-accent);
    transition: all 0.3s ease;
  }

  .markdown-content a:hover {
    color: var(--color-text-primary);
    border-bottom-style: solid;
    text-shadow: 0 0 8px var(--page-accent);
  }

  .markdown-content ul, 
  .markdown-content ol {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .markdown-content li {
    margin-bottom: 8px;
  }

  /* 赛博朋克引用区 */
  .markdown-content blockquote {
    background: hsla(var(--page-primary-h), var(--page-primary-s), var(--page-primary-l), 0.04);
    border-left: 4px solid var(--page-primary);
    border-radius: 0 4px 4px 0;
    padding: 20px 24px;
    margin: 32px 0;
    font-style: italic;
    color: var(--color-text-secondary);
    box-shadow: inset 2px 0 10px hsla(var(--page-primary-h), var(--page-primary-s), var(--page-primary-l), 0.05);
  }

  .markdown-content blockquote p:last-child {
    margin-bottom: 0;
  }

  /* 高亮代码块 */
  .markdown-content pre {
    background: color-mix(in srgb, var(--color-bg-base) 95%, transparent) !important;
    border: 1px solid var(--color-border-subtle);
    border-left: 3px solid var(--page-accent);
    border-radius: 4px;
    padding: 20px;
    margin: 32px 0;
    overflow-x: auto;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.4);
  }

  .markdown-content code {
    background: rgba(255, 255, 255, 0.05);
    color: var(--page-primary);
    border: 1px solid var(--color-border-subtle);
    border-radius: 4px;
    padding: 2px 6px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
  }

  .markdown-content pre code {
    background: transparent;
    color: inherit;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  /* 表格样式 */
  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 32px 0;
    font-size: 0.95rem;
    background: rgba(255, 255, 255, 0.01);
  }

  .markdown-content th, 
  .markdown-content td {
    padding: 12px 16px;
    border: 1px solid var(--color-border-subtle);
    text-align: left;
  }

  .markdown-content th {
    background: hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.05);
    color: var(--page-accent);
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    border-bottom: 2px solid hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.3);
  }

  .markdown-content tr:nth-child(even) {
    background: rgba(255, 255, 255, 0.02);
  }

  .markdown-content tr:hover {
    background: hsla(var(--page-accent-h), var(--page-accent-s), var(--page-accent-l), 0.03);
  }

  /* 水平分割线 */
  .markdown-content hr {
    border: none;
    border-bottom: 1px dashed var(--color-border-subtle);
    margin: 48px 0;
    position: relative;
  }

  .markdown-content hr::before {
    content: "☠";
    color: var(--color-text-muted);
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-bg-base);
    padding: 0 10px;
  }
</style>
