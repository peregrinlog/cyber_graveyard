---
// src/components/ProjectDirectory.astro
import type { CollectionEntry } from 'astro:content';
import Tombstone from './Tombstone.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
---

<div class="directory-container">
  <!-- 搜索与筛选面板 // SEARCH & FILTER PANEL -->
  <div class="filter-panel">
    <div class="search-box-wrapper">
      <span class="search-icon">🔍</span>
      <input 
        type="text" 
        id="directorySearch" 
        placeholder="搜索项目名称、死因或技术栈... // SEARCH" 
        class="cyber-search-input"
        autocomplete="off"
      />
      <div class="search-glow-bar"></div>
    </div>
    
    <div class="filter-tabs-wrapper">
      <button class="filter-tab active" data-status="all">
        <span class="tab-indicator"></span>
        ALL // 全部
      </button>
      <button class="filter-tab" data-status="terminated" style="--tab-color: var(--color-status-terminated)">
        <span class="tab-indicator" style="background: var(--color-status-terminated)"></span>
        TERMINATED
      </button>
      <button class="filter-tab" data-status="abandoned" style="--tab-color: var(--color-status-abandoned)">
        <span class="tab-indicator" style="background: var(--color-status-abandoned)"></span>
        ABANDONED
      </button>
      <button class="filter-tab" data-status="deprecated" style="--tab-color: var(--color-status-deprecated)">
        <span class="tab-indicator" style="background: var(--color-status-deprecated)"></span>
        DEPRECATED
      </button>
      <button class="filter-tab" data-status="liquidated" style="--tab-color: var(--color-status-liquidated)">
        <span class="tab-indicator" style="background: var(--color-status-liquidated)"></span>
        LIQUIDATED
      </button>
      <button class="filter-tab" data-status="delisted" style="--tab-color: var(--color-status-delisted)">
        <span class="tab-indicator" style="background: var(--color-status-delisted)"></span>
        DELISTED
      </button>
    </div>
  </div>

  <!-- 墓碑网格列表 // TOMBSTONE GRID -->
  <main class="graveyard" id="graveyardGrid">
    {projects.map((project) => (
      <a 
        href={`/projects/${project.id.replace(/\.md$/, '')}`} 
        class="tombstone-wrapper-link" 
        data-title={project.data.title.toLowerCase()}
        data-cause={project.data.cause.toLowerCase()}
        data-tech={project.data.tech.join(',').toLowerCase()}
        data-status={project.data.status}
        style="text-decoration: none; display: block; color: inherit;"
      >
        <Tombstone project={project} />
      </a>
    ))}
  </main>

  <!-- 空搜索报错卡片 // EMPTY SEARCH STATE -->
  <div class="cyber-empty-state" id="emptyState">
    <div class="empty-state-card">
      <div class="card-glitch-overlay"></div>
      <div class="error-header">
        <span class="warning-light">⚠️</span>
        <h3>[SYSTEM ERROR: NO SOULS DETECTED]</h3>
      </div>
      <div class="error-body">
        <p class="error-code">STATUS_CODE: 0xDEAD_BEEF // NULL_SEARCH_RESULT</p>
        <div class="terminal-text">
          <p class="line">&gt; Initializing search sweep in cyber graveyard...</p>
          <p class="line">&gt; Scanning sector tags: "<span id="emptyStateTag">ALL</span>"</p>
          <p class="line">&gt; Query match criteria: "<span id="emptyStateQuery">None</span>"</p>
          <p class="line error-alert">&gt; ALERT: Zero digital remains or lost souls detected in this sector.</p>
          <p class="line">&gt; Action recommended: recalibrate filters and reset search parameters.</p>
        </div>
        <button class="reset-search-btn" id="resetSearchBtn">
          RECALIBRATE SENSORS // RESET FILTERS
        </button>
      </div>
      <div class="card-footer-lines"></div>
    </div>
  </div>
</div>

<style>
  .directory-container {
    width: 100%;
  }

  /* 搜索与筛选面板 */
  .filter-panel {
    max-width: 1400px;
    margin: 0 auto 30px;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (min-width: 992px) {
    .filter-panel {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  /* 搜索框 */
  .search-box-wrapper {
    position: relative;
    flex: 1;
    max-width: 500px;
  }

  .search-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: hsla(var(--color-secondary-h), var(--color-secondary-s), var(--color-secondary-l), 0.5);
    font-size: 0.95rem;
  }

  .cyber-search-input {
    width: 100%;
    padding: 12px 16px 12px 42px;
    background: rgba(5, 5, 8, 0.95);
    border: 1px solid hsla(var(--color-secondary-h), var(--color-secondary-s), var(--color-secondary-l), 0.2);
    border-radius: 4px;
    color: var(--color-text-primary);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
  }

  .cyber-search-input:focus {
    outline: none;
    border-color: var(--color-secondary);
    box-shadow: 0 0 15px hsla(var(--color-secondary-h), var(--color-secondary-s), var(--color-secondary-l), 0.25);
  }

  .search-glow-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-secondary);
    box-shadow: 0 0 8px var(--color-secondary);
    transition: width 0.3s ease;
  }

  .cyber-search-input:focus ~ .search-glow-bar {
    width: 100%;
  }

  /* 筛选页签 */
  .filter-tabs-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .filter-tab {
    background: rgba(5, 5, 8, 0.95);
    border: 1px solid var(--color-border-subtle);
    border-radius: 4px;
    color: var(--color-text-muted);
    padding: 8px 16px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.8rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }

  .tab-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-muted);
    display: inline-block;
    transition: all 0.3s ease;
  }

  .filter-tab:hover {
    color: var(--color-text-primary);
    border-color: rgba(255, 255, 255, 0.35);
  }

  .filter-tab.active {
    color: var(--tab-color, var(--color-secondary));
    border-color: var(--tab-color, var(--color-secondary));
    box-shadow: 0 0 12px hsla(var(--color-secondary-h), var(--color-secondary-s), var(--color-secondary-l), 0.15);
    text-shadow: 0 0 5px hsla(var(--color-secondary-h), var(--color-secondary-s), var(--color-secondary-l), 0.2);
    background: hsla(var(--color-secondary-h), var(--color-secondary-s), var(--color-secondary-l), 0.03);
  }

  .filter-tab.active[data-status="all"] {
    --tab-color: var(--color-secondary);
  }

  /* 墓碑网格 */
  .graveyard {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 30px;
  }

  /* 卡片样式已移至 Tombstone.astro，仅保留列表基底样式 */

  /* 过滤动画样式 */
  .tombstone-wrapper-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1), transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tombstone-wrapper-link.filtered-out {
    opacity: 0;
    transform: scale(0.85);
    pointer-events: none;
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    border: none;
  }

  /* 空搜索报错卡片样式 */
  .cyber-empty-state {
    display: none;
    max-width: 680px;
    margin: 40px auto;
    padding: 0 20px;
    animation: glitchShow 0.4s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  .cyber-empty-state.active {
    display: block;
  }

  @keyframes glitchShow {
    0% {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .empty-state-card {
    background: color-mix(in srgb, var(--color-bg-base) 92%, transparent);
    border: 2px solid var(--color-primary);
    border-radius: 8px;
    padding: 30px;
    box-shadow: 
      0 0 20px hsla(var(--color-primary-h), var(--color-primary-s), var(--color-primary-l), 0.15),
      inset 0 0 15px hsla(var(--color-primary-h), var(--color-primary-s), var(--color-primary-l), 0.05);
    position: relative;
    overflow: hidden;
  }

  .empty-state-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-warning), var(--color-primary));
    box-shadow: 0 2px 10px var(--color-primary);
  }

  .card-glitch-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      0deg,
      hsla(var(--color-primary-h), var(--color-primary-s), var(--color-primary-l), 0.02) 0px,
      hsla(var(--color-primary-h), var(--color-primary-s), var(--color-primary-l), 0.02) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
  }

  .error-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 20px;
    border-bottom: 1px dashed hsla(var(--color-primary-h), var(--color-primary-s), var(--color-primary-l), 0.3);
    padding-bottom: 15px;
  }

  .warning-light {
    font-size: 1.8rem;
    animation: alertBlink 1s infinite alternate;
  }

  @keyframes alertBlink {
    0% { opacity: 0.3; filter: drop-shadow(0 0 2px var(--color-primary)); }
    100% { opacity: 1; filter: drop-shadow(0 0 10px var(--color-primary)); }
  }

  .error-header h3 {
    font-family: 'Orbitron', sans-serif;
    color: var(--color-primary);
    text-shadow: 0 0 8px hsla(var(--color-primary-h), var(--color-primary-s), var(--color-primary-l), 0.4);
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .error-body {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .error-code {
    font-size: 0.85rem;
    color: var(--color-warning);
    font-family: 'Share Tech Mono', monospace;
    font-weight: bold;
    letter-spacing: 0.05em;
  }

  .terminal-text {
    background: color-mix(in srgb, var(--palette-dark-900) 80%, transparent);
    border: 1px solid var(--color-border-subtle);
    border-radius: 4px;
    padding: 15px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .terminal-text .line {
    margin: 0;
  }

  .terminal-text .line span {
    color: var(--color-secondary);
    font-weight: bold;
  }

  .terminal-text .error-alert {
    color: var(--color-primary);
    font-weight: bold;
    text-shadow: 0 0 5px hsla(var(--color-primary-h), var(--color-primary-s), var(--color-primary-l), 0.2);
  }

  .reset-search-btn {
    margin-top: 10px;
    align-self: flex-start;
    background: transparent;
    border: 1px solid var(--color-secondary);
    color: var(--color-secondary);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    font-weight: bold;
    padding: 10px 20px;
    border-radius: 4px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 10px hsla(0, 0%, 0%, 0.3);
  }

  .reset-search-btn:hover {
    background: var(--color-secondary);
    color: var(--color-bg-base);
    box-shadow: 0 0 15px var(--color-secondary);
    transform: translateY(-2px);
  }

  .reset-search-btn:active {
    transform: translateY(0);
  }

  .card-footer-lines {
    position: absolute;
    bottom: 5px;
    right: 15px;
    width: 60px;
    height: 4px;
    border-top: 1px solid var(--color-primary);
    border-bottom: 1px solid var(--color-primary);
    opacity: 0.5;
  }

  /* 响应式设计 */
  @media (max-width: 768px) {
    .graveyard {
      grid-template-columns: 1fr;
      padding: 10px 15px 30px;
    }
  }
</style>

<script>
  function initDirectoryFilters() {
    const searchInput = document.getElementById('directorySearch') as HTMLInputElement | null;
    const filterTabs = document.querySelectorAll('.filter-tab');
    const projectCards = document.querySelectorAll('.tombstone-wrapper-link');

    if (!projectCards.length) return;

    let activeFilter = 'all';
    let searchQuery = '';

    function filterProjects() {
      let visibleCount = 0;
      projectCards.forEach((card) => {
        const title = card.getAttribute('data-title') || '';
        const cause = card.getAttribute('data-cause') || '';
        const tech = card.getAttribute('data-tech') || '';
        const status = card.getAttribute('data-status') || '';

        const matchesSearch = 
          title.includes(searchQuery) || 
          cause.includes(searchQuery) || 
          tech.includes(searchQuery);

        const matchesStatus = 
          activeFilter === 'all' || 
          status === activeFilter;

        if (matchesSearch && matchesStatus) {
          card.classList.remove('filtered-out');
          visibleCount++;
        } else {
          card.classList.add('filtered-out');
        }
      });

      // 控制空状态报错卡片的显示/隐藏
      const emptyState = document.getElementById('emptyState');
      const emptyStateTag = document.getElementById('emptyStateTag');
      const emptyStateQuery = document.getElementById('emptyStateQuery');

      if (emptyState) {
        if (visibleCount === 0) {
          if (emptyStateTag) {
            emptyStateTag.textContent = activeFilter.toUpperCase();
          }
          if (emptyStateQuery) {
            emptyStateQuery.textContent = searchQuery || 'None';
          }
          emptyState.classList.add('active');
        } else {
          emptyState.classList.remove('active');
        }
      }
    }

    // 绑定搜索输入事件
    if (searchInput) {
      searchInput.value = '';
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
        filterProjects();
      });
    }

    // 绑定筛选标签点击事件
    filterTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        filterTabs.forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        
        activeFilter = tab.getAttribute('data-status') || 'all';
        filterProjects();
      });
    });

    // 绑定重置按钮事件
    const resetSearchBtn = document.getElementById('resetSearchBtn');
    if (resetSearchBtn) {
      resetSearchBtn.addEventListener('click', () => {
        if (searchInput) {
          searchInput.value = '';
          searchQuery = '';
        }
        activeFilter = 'all';
        filterTabs.forEach((t) => {
          if (t.getAttribute('data-status') === 'all') {
            t.classList.add('active');
          } else {
            t.classList.remove('active');
          }
        });
        filterProjects();
      });
    }

    // 鼠标移动卡片视差效果 (Card Parallax on Mouse Move)
    let isMoving = false;
    document.addEventListener('mousemove', (e) => {
      if (isMoving) return;
      isMoving = true;
      
      requestAnimationFrame(() => {
        const activeCards = document.querySelectorAll('.tombstone-wrapper-link:not(.filtered-out) .tombstone');
        const mouseX = e.clientX / window.innerWidth - 0.5;
        const mouseY = e.clientY / window.innerHeight - 0.5;
        
        activeCards.forEach((card, index) => {
          const htmlCard = card as HTMLElement;
          const speed = (index % 3 + 1) * 3; // 视差位移系数
          const x = mouseX * speed;
          const y = mouseY * speed;
          htmlCard.style.transform = `translate(${x}px, ${y}px)`;
        });
        
        isMoving = false;
      });
    });
  }

  // 兼容 Astro View Transitions
  document.addEventListener('astro:page-load', initDirectoryFilters);
  // 普通加载备用
  initDirectoryFilters();
</script>
