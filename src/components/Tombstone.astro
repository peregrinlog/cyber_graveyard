---
// src/components/Tombstone.astro
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article class={`tombstone status-${project.data.status}`}>
  <div class="rip-mark">☠️</div>
  
  <div class="tombstone-header">
    <div>
      <h2 class="project-name">{project.data.title}</h2>
      <span class="status-badge">
        {project.data.status}
      </span>
    </div>
    
    <button 
      class="ritual-btn" 
      data-project-title={project.data.title}
      title="进行赛博超度仪式 // PERFORM RITUAL"
    >
      <span class="ritual-emoji">🕯️</span>
      <span class="ritual-text">超度</span>
    </button>
  </div>
  
  <div class="death-date">{project.data.deathDate}</div>
  
  <div class="cause-of-death">
    <span class="cause-label">死因 / CAUSE OF DEATH</span>
    {project.data.cause}
  </div>
  
  <div class="tech-stack">
    {project.data.tech.map(tech => (
      <span class="tech-tag">{tech}</span>
    ))}
  </div>
  
  <p class="epitaph">{project.data.epitaph}</p>
</article>

<style>
  /* 墓碑卡片 */
  .tombstone {
    background: linear-gradient(145deg, var(--color-bg-surface-elevated), var(--color-bg-base));
    border: 2px solid var(--color-border-subtle);
    border-radius: 10px;
    padding: 30px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), border-color 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tombstone::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      hsla(var(--color-status-current-h), var(--color-status-current-s), var(--color-status-current-l), 0.1),
      transparent
    );
    transition: left 0.5s ease;
  }

  .tombstone:hover::before {
    left: 100%;
  }

  .tombstone:hover {
    border-color: var(--color-status-current);
    box-shadow: 
      0 10px 30px hsla(var(--color-status-current-h), var(--color-status-current-s), var(--color-status-current-l), 0.2),
      0 0 20px hsla(var(--color-status-current-h), var(--color-status-current-s), var(--color-status-current-l), 0.1);
  }

  /* 状态自适应绑定 */
  .tombstone.status-terminated {
    --color-status-current: var(--color-status-terminated);
    --color-status-current-h: var(--color-primary-h);
    --color-status-current-s: var(--color-primary-s);
    --color-status-current-l: var(--color-primary-l);
  }
  .tombstone.status-abandoned {
    --color-status-current: var(--color-status-abandoned);
    --color-status-current-h: var(--color-accent-h);
    --color-status-current-s: var(--color-accent-s);
    --color-status-current-l: var(--color-accent-l);
  }
  .tombstone.status-deprecated {
    --color-status-current: var(--color-status-deprecated);
    --color-status-current-h: var(--color-secondary-h);
    --color-status-current-s: var(--color-secondary-s);
    --color-status-current-l: var(--color-secondary-l);
  }
  .tombstone.status-liquidated {
    --color-status-current: var(--color-status-liquidated);
    --color-status-current-h: var(--color-warning-h);
    --color-status-current-s: var(--color-warning-s);
    --color-status-current-l: var(--color-warning-l);
  }
  .tombstone.status-delisted {
    --color-status-current: var(--color-status-delisted);
    --color-status-current-h: var(--color-decorative-h);
    --color-status-current-s: var(--color-decorative-s);
    --color-status-current-l: var(--color-decorative-l);
  }

  .tombstone-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
  }

  .project-name {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 5px;
  }

  .status-badge {
    font-size: 0.75rem;
    padding: 4px 12px;
    border-radius: 20px;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
    background: rgba(0, 0, 0, 0.5);
    color: var(--color-status-current);
    border: 1px solid var(--color-status-current);
  }

  .ritual-btn {
    background: rgba(5, 5, 8, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--color-text-secondary);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
    z-index: 10;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.3);
    min-width: 54px;
  }

  .ritual-emoji {
    font-size: 1.15rem;
    line-height: 1;
    filter: drop-shadow(0 0 3px var(--color-status-current));
  }

  .ritual-text {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
  }

  .ritual-btn:hover {
    background: hsla(var(--color-status-current-h), var(--color-status-current-s), var(--color-status-current-l), 0.15);
    border-color: var(--color-status-current);
    color: var(--color-text-primary);
    box-shadow: 0 0 10px hsla(var(--color-status-current-h), var(--color-status-current-s), var(--color-status-current-l), 0.4);
    transform: translateY(-1px) scale(1.05);
  }

  .ritual-btn:active {
    transform: translateY(1px) scale(0.95);
  }

  .death-date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 15px;
  }

  .death-date::before {
    content: '💀 ';
  }

  .cause-of-death {
    background: hsla(var(--color-status-current-h), var(--color-status-current-s), var(--color-status-current-l), 0.05);
    border-left: 3px solid var(--color-status-current);
    padding: 10px 15px;
    margin: 15px 0;
    font-size: 0.9rem;
    color: hsla(var(--color-status-current-h), var(--color-status-current-s), 80%, 1);
  }

  .cause-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 5px;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 15px 0;
  }

  .tech-tag {
    font-size: 0.75rem;
    padding: 4px 10px;
    background: hsla(var(--color-status-current-h), var(--color-status-current-s), var(--color-status-current-l), 0.06);
    color: var(--color-status-current);
    border: 1px solid hsla(var(--color-status-current-h), var(--color-status-current-s), var(--color-status-current-l), 0.15);
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .epitaph {
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    padding-top: 15px;
    border-top: 1px dashed var(--color-border-subtle);
    text-align: center;
    margin-top: auto;
  }

  .epitaph::before {
    content: '"';
    font-size: 1.5rem;
    color: var(--color-status-current);
    opacity: 0.8;
  }

  .epitaph::after {
    content: '"';
    font-size: 1.5rem;
    color: var(--color-status-current);
    opacity: 0.8;
  }

  .rip-mark {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 1.5rem;
    opacity: 0.2;
    transform: rotate(15deg);
  }
</style>

<script>
  function setupRitualTriggers() {
    const ritualBtns = document.querySelectorAll('.ritual-btn');
    ritualBtns.forEach(btn => {
      // 避免重复绑定
      btn.removeEventListener('click', handleRitualClick);
      btn.addEventListener('click', handleRitualClick);
    });
  }

  function handleRitualClick(e: Event) {
    e.preventDefault();
    e.stopPropagation();
    
    const btn = e.currentTarget as HTMLElement;
    const title = btn.getAttribute('data-project-title') || '无名项目';
    
    // 派发自定义全局事件
    const event = new CustomEvent('open-ritual-modal', {
      detail: { title }
    });
    window.dispatchEvent(event);
  }

  // 支持 View Transitions
  document.addEventListener('astro:page-load', setupRitualTriggers);
  setupRitualTriggers();
</script>
