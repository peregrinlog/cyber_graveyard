---
// src/components/TableOfContents.astro
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// 只展示 H2 和 H3 级别的目录项
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filteredHeadings.length > 0 && (
  <nav class="toc-container" aria-label="Table of contents">
    <div class="toc-header">
      <span class="toc-header-icon">🛰️</span>
      <span class="toc-header-text">SYSTEM OUTLINE // 目录体系</span>
    </div>
    
    <div class="toc-ruler-wrapper">
      <div class="toc-progress-line">
        <div class="toc-progress-fill" id="tocProgressFill"></div>
      </div>
      
      <ul class="toc-list">
        {filteredHeadings.map((heading) => (
          <li class={`toc-item depth-${heading.depth}`}>
            <a href={`#${heading.slug}`} class="toc-link" data-slug={heading.slug}>
              <span class="toc-tick"></span>
              <span class="toc-text">{heading.text}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<style>
  .toc-container {
    --toc-accent: var(--page-accent, var(--color-secondary));
    --toc-accent-h: var(--page-accent-h, var(--color-secondary-h));
    --toc-accent-s: var(--page-accent-s, var(--color-secondary-s));
    --toc-accent-l: var(--page-accent-l, var(--color-secondary-l));

    --toc-primary: var(--page-primary, var(--color-primary));
    --toc-primary-h: var(--page-primary-h, var(--color-primary-h));
    --toc-primary-s: var(--page-primary-s, var(--color-primary-s));
    --toc-primary-l: var(--page-primary-l, var(--color-primary-l));

    background: linear-gradient(180deg, color-mix(in srgb, var(--color-bg-surface) 95%, transparent) 0%, color-mix(in srgb, var(--color-bg-base) 98%, transparent) 100%);
    border: 1px solid var(--color-border-accent);
    border-left: 3px solid var(--toc-primary);
    border-radius: 6px;
    padding: 24px 20px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    width: 100%;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
    font-family: 'Share Tech Mono', 'Noto Sans SC', monospace;
  }

  /* 自定义滚动条风格 */
  .toc-container::-webkit-scrollbar {
    width: 4px;
  }
  .toc-container::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
  }
  .toc-container::-webkit-scrollbar-thumb {
    background: hsla(var(--toc-accent-h), var(--toc-accent-s), var(--toc-accent-l), 0.2);
    border-radius: 2px;
  }
  .toc-container::-webkit-scrollbar-thumb:hover {
    background: var(--toc-accent);
  }

  .toc-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    color: var(--toc-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px dashed var(--color-border-subtle);
    padding-bottom: 12px;
    margin-bottom: 18px;
  }

  .toc-header-icon {
    font-size: 0.9rem;
    animation: pulse 2s infinite alternate;
  }

  @keyframes pulse {
    0% { opacity: 0.6; }
    100% { opacity: 1; filter: drop-shadow(0 0 4px var(--toc-primary)); }
  }

  .toc-ruler-wrapper {
    position: relative;
    padding-left: 20px;
  }

  /* 垂直进度标尺 */
  .toc-progress-line {
    position: absolute;
    left: 0;
    top: 5px;
    bottom: 5px;
    width: 2px;
    background: var(--color-border-subtle);
  }

  .toc-progress-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: var(--toc-accent);
    box-shadow: 0 0 8px var(--toc-accent);
    transition: height 0.15s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin-bottom: 14px;
    position: relative;
  }

  .toc-item:last-child {
    margin-bottom: 0;
  }

  .toc-item.depth-3 {
    padding-left: 15px;
  }

  .toc-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    transition: all 0.25s ease;
    line-height: 1.4;
  }

  /* 标尺刻度 tick */
  .toc-tick {
    position: absolute;
    left: -20px;
    width: 8px;
    height: 2px;
    background: var(--color-border-subtle);
    transition: all 0.25s ease;
  }

  .toc-item.depth-3 .toc-tick {
    left: -5px;
    width: 5px;
    background: var(--color-border-subtle);
  }

  .toc-text {
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .toc-link:hover {
    color: var(--color-text-primary);
    text-shadow: 0 0 6px hsla(0, 0%, 100%, 0.4);
  }

  .toc-link:hover .toc-tick {
    background: var(--toc-primary);
    width: 12px;
    box-shadow: 0 0 6px var(--toc-primary);
  }

  /* 激活状态 */
  .toc-item.active .toc-link {
    color: var(--toc-accent);
    font-weight: 700;
    text-shadow: 0 0 8px hsla(var(--toc-accent-h), var(--toc-accent-s), var(--toc-accent-l), 0.4);
  }

  .toc-item.active .toc-tick {
    background: var(--toc-accent);
    width: 14px;
    box-shadow: 0 0 8px var(--toc-accent);
  }
</style>

<script>
  function initScrollSpy() {
    const tocItems = document.querySelectorAll('.toc-item');
    const tocLinks = document.querySelectorAll('.toc-link');
    const progressFill = document.getElementById('tocProgressFill');
    
    if (tocItems.length === 0) return;

    // 获取所有目录项对应的 DOM 元素
    const targets = Array.from(tocLinks).map(link => {
      const slug = link.getAttribute('data-slug');
      // Astro header IDs are sometimes encoded or contain special characters, so we handle standard decodes
      const decodedSlug = decodeURIComponent(slug || '');
      const target = document.getElementById(decodedSlug) || document.getElementById(slug || '');
      return { link, target, slug };
    }).filter(item => item.target !== null);

    if (targets.length === 0) return;

    let isScrolling = false;

    function onScroll() {
      if (isScrolling) return;
      isScrolling = true;

      requestAnimationFrame(() => {
        const scrollPos = window.scrollY || window.pageYOffset;
        const windowHeight = window.innerHeight;
        const docHeight = document.documentElement.scrollHeight - windowHeight;
        
        // 更新目录进度条
        if (progressFill && docHeight > 0) {
          const scrollPercent = (scrollPos / docHeight) * 100;
          progressFill.style.height = `${Math.min(scrollPercent, 100)}%`;
        }

        // 计算当前激活的标题段落
        let activeIndex = -1;
        
        // 阈值：离视口顶部 150 像素
        const threshold = 150;
        
        for (let i = 0; i < targets.length; i++) {
          const targetTop = targets[i].target.getBoundingClientRect().top + scrollPos;
          if (scrollPos >= targetTop - threshold) {
            activeIndex = i;
          } else {
            break;
          }
        }

        // 清除所有 active 状态
        tocItems.forEach(item => item.classList.remove('active'));

        // 设置当前激活项
        if (activeIndex !== -1) {
          const activeLink = targets[activeIndex].link;
          const activeItem = activeLink.closest('.toc-item');
          if (activeItem) {
            activeItem.classList.add('active');
          }
        } else if (targets.length > 0) {
          // 默认激活第一个
          const firstItem = targets[0].link.closest('.toc-item');
          if (firstItem) {
            firstItem.classList.add('active');
          }
        }

        isScrolling = false;
      });
    }

    // 平滑锚点点击滚动
    tocLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = link.getAttribute('data-slug');
        const decodedSlug = decodeURIComponent(slug || '');
        const target = document.getElementById(decodedSlug) || document.getElementById(slug || '');
        if (target) {
          const targetTop = target.getBoundingClientRect().top + window.scrollY;
          window.scrollTo({
            top: targetTop - 100,
            behavior: 'smooth'
          });
          
          // 手动设置 active 状态并更新 hash
          setTimeout(() => {
            history.pushState(null, '', `#${slug}`);
          }, 500);
        }
      });
    });

    window.addEventListener('scroll', onScroll);
    // 初始化执行一次
    onScroll();
  }

  // 兼容 Astro View Transitions
  document.addEventListener('astro:page-load', initScrollSpy);
  // 普通加载备用
  initScrollSpy();
</script>
